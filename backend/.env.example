# ========================================
# KOOVE ORGANIC BACKEND CONFIGURATION
# ========================================
#
# SECURITY WARNING:
# - Never commit this file with real values to version control
# - Keep all sensitive tokens and keys secure
# - Rotate tokens regularly
# - Use different tokens for development and production
#
# Setup Instructions:
# 1. Copy this file to .env
# 2. Replace all placeholder values with your actual credentials
# 3. Ensure .env is in your .gitignore file
# ========================================

# Server Configuration
PORT=3002
NODE_ENV=development

# ATS Database Connection (for reading approved vacancies)
# Since both website and ATS are on the same cPanel server,
# we connect directly to the ATS database to read approved vacancies
# Option 1: Connection string (recommended)
ATS_DATABASE_URL=postgresql://atsrashmimetalik_atsuser:your_password@localhost:5432/atsrashmimetalik_ats

# Option 2: Individual connection parameters
# ATS_PGHOST=localhost
# ATS_PGPORT=5432
# ATS_PGDATABASE=atsrashmimetalik_ats
# ATS_PGUSER=atsrashmimetalik_atsuser
# ATS_PGPASSWORD=your_password
# PG_SSL=false

# CMS Configuration (Strapi)
# IMPORTANT: Use a secure API token, not the default one
# Production example: https://kooveorganic.com/strapi (adjust if Strapi is hosted elsewhere)
CMS_API_URL=https://kooveorganic.com/strapi
CMS_API_TOKEN=your_secure_strapi_api_token_here
CMS_NEWS_API_ID=news-and-updates
CMS_NEWS_PANEL_API_ID=news-and-updates-panel

# CORS Configuration (comma-separated = multiple allowed browser origins)
# Local dev: Vite default 5173 and optional alternate port
CORS_ORIGIN=http://localhost:5173,http://localhost:8080
# Production example (uncomment and use on server):
# CORS_ORIGIN=https://kooveorganic.com,https://www.kooveorganic.com

# reCAPTCHA Configuration
# Get your keys from Google reCAPTCHA console
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here

# Email Configuration (SMTP) — Contact form & related
# Primary (recommended): enquiry inbox
ENQUIRY_EMAIL_USER=your_enquiry_inbox@yourdomain.com
ENQUIRY_EMAIL_PASS=your_smtp_app_password_or_secret
# Alternative: same values as below — contact service also reads EMAIL_USER / EMAIL_PASS if ENQUIRY_* are unset
# ENQUIRY_EMAIL_USER=
# ENQUIRY_EMAIL_PASS=
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_fallback_smtp_user@yourdomain.com
EMAIL_PASS=your_fallback_smtp_password_or_app_secret
